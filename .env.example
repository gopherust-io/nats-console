# Local development (optional — loaded by the server on startup)
ENV=development
DATABASE_URL=postgres://natsconsol:natsconsol@localhost:5432/natsconsol?sslmode=disable
NATS_URL=nats://localhost:4222
NATS_MONITORING_URL=http://localhost:8222
AUTH_ENABLED=false
HTTP_ADDR=:8080
DEFAULT_CLUSTER_NAME=default

# Optional tuning (defaults match current behavior)
# HTTP_READ_TIMEOUT=10s
# HTTP_WRITE_TIMEOUT=30s
# HTTP_IDLE_TIMEOUT=60s
# PUBLIC_BASE_URL=http://localhost:8080
# PAGINATION_DEFAULT_LIMIT=100
# PAGINATION_MAX_LIMIT=500
# LIVE_WS_MAX_MESSAGES=1000
# MAX_REQUEST_BODY_SIZE=1048576
# AUTH_RATE_LIMIT=10
# AUTH_RATE_LIMIT_WINDOW=1m

# Go runtime profiling (admin-only)
PPROF_ENABLED=true
PPROF_AUTH_ENABLED=true
PPROF_CONTINUOUS=true
# PPROF_CONTINUOUS_INTERVAL=15s
# PPROF_CONTINUOUS_CPU_SLICE=5s
# PPROF_CPU_MAX_SECONDS=120

# v0.3 enterprise (optional in development, required in production)
# ENCRYPTION_KEY=change-me-to-a-long-random-secret
# SESSION_SECRET=another-long-random-secret
# LOG_JSON=false
# LOG_LEVEL=info
# CORS_ALLOWED_ORIGINS=http://localhost:5173

# OIDC SSO — generic provider (Keycloak, Okta, etc.)
# OIDC_ENABLED=true
# OIDC_ISSUER=http://localhost:8180/realms/nats-consol
# OIDC_DISCOVERY_URL=http://keycloak:8080/realms/nats-consol
# OIDC_CLIENT_ID=nats-consol
# OIDC_CLIENT_SECRET=nats-consol-dev-secret
# OIDC_REDIRECT_URL=http://localhost:8080/api/v1/auth/oidc/callback
# OIDC_PUBLIC_URL=http://localhost:8080

# Social / enterprise SSO providers (each uses /api/v1/auth/oidc/{provider}/callback)
# OIDC_GOOGLE_ENABLED=true
# OIDC_GOOGLE_CLIENT_ID=
# OIDC_GOOGLE_CLIENT_SECRET=
# OIDC_GITHUB_ENABLED=true
# OIDC_GITHUB_CLIENT_ID=
# OIDC_GITHUB_CLIENT_SECRET=
# OIDC_GITLAB_ENABLED=true
# OIDC_GITLAB_CLIENT_ID=
# OIDC_GITLAB_CLIENT_SECRET=
# OIDC_GITLAB_BASE_URL=https://gitlab.com
# OIDC_MICROSOFT_ENABLED=true
# OIDC_MICROSOFT_CLIENT_ID=
# OIDC_MICROSOFT_CLIENT_SECRET=
# OIDC_MICROSOFT_TENANT=common
# BASIC_AUTH_ENABLED=true

# Bootstrap root account (seeded on first start when no users exist)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me-in-production

# AI assistant (Gemini — NATS JetStream context only)
# AI_ENABLED=true
# AI_API_KEY=your-gemini-api-key
# AI_MODEL=gemini-2.5-flash
