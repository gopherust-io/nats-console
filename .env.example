# Local development (optional — loaded by the server on startup)
ENV=development
DATABASE_URL=postgres://natsconsol:natsconsol@localhost:5432/natsconsol?sslmode=disable
NATS_URL=nats://localhost:4222
NATS_MONITORING_URL=http://localhost:8222
AUTH_ENABLED=false
HTTP_ADDR=:8080
DEFAULT_CLUSTER_NAME=default

# v0.3 enterprise (optional in development, required in production)
# ENCRYPTION_KEY=change-me-to-a-long-random-secret
# SESSION_SECRET=another-long-random-secret
# LOG_JSON=false
# CORS_ALLOWED_ORIGINS=http://localhost:5173

# OIDC SSO (optional — set OIDC_ENABLED=true for SSO)
# OIDC_ENABLED=false
# OIDC_ISSUER=https://login.example.com/realms/nats
# OIDC_CLIENT_ID=nats-consol
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URL=http://localhost:8080/api/v1/auth/oidc/callback
# BASIC_AUTH_ENABLED=true

# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin
